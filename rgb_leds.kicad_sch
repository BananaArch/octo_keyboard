	(text "Daisy-Chained SK6812 MINI-E RGB LEDs"
		(exclude_from_sim no)
		(at 179.324 131.064 0)
		(effects
			(font
				(size 10.16 10.16)
				(thickness 2.032)
				(bold yes)
			)
		)
		(uuid "503cca8b-aaa3-4cd3-97e1-0a5b67b040d1")
	)
	(text "BRIDGES and 330-OHM SERIES RESISTOR"
		(exclude_from_sim no)
		(at 60.198 16.764 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "66a27db9-bc8e-443c-861a-e0d3fd3014a0")
	)
	(text "3.3V <-> 5V Level Shifter"
		(exclude_from_sim no)
		(at 176.022 16.764 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "7ff7b05f-17f1-4fed-93f8-6e79d0968411")
	)
	(text_box "The Level Shifter is required because the LEDs operate on a 5V supply and require a logic high signal typically above 3.5V (0.7 * V_{DD}). Since the STM32 outputs 3.3V, the level shifter bridges this gap to ensure reliable data transmission and prevent flickering. The schematic is based on the recommended application schematic from the datasheet (https://www.ti.com/lit/ds/symlink/txu0101.pdf?ts=1775468435639)."
		(exclude_from_sim no)
		(at 149.86 73.66 0)
		(size 92.71 12.1268)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
				(color 72 72 72 1)
			)
			(justify left top)
		)
		(uuid "1a6d7561-5852-419a-9f2e-8a1b84e0ccb7")
	)
	(text_box "The purpose of the two bridges is to experiment & test how the LED daisy-chain behaves with and without the level shifter. This is just for me to understand the adverse effects the lack of a level shifter causes and if the tolerance on the LEDs is enough to forgo the need for a level shifter. The 330 ohm series resistor is there to impedance match and reduce the current inrush to the first LED. The 330 ohm resistor is based on Adafruit's recommendation for Neopixels (https://learn.adafruit.com/adafruit-neopixel-uberguide/best-practices)"
		(exclude_from_sim no)
		(at 20.32 49.53 0)
		(size 100.33 15.24)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
				(color 72 72 72 1)
			)
			(justify left top)
		)
		(uuid "d492e61d-0a8e-4d50-ac68-a7b9cf7e8623")
	)
